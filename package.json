{
  "name": "bao",
  "version": "1.0.0",
  "description": "The most powerful Markdown editor that you've ever seen.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.bao.app",
    "productName": "Bao",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "directories": {
      "output": "release"
    },
    "icon": "public/logo_color.png",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/logo_color.png",
      "target": [
        "dmg",
        "dir"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "dir"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "dir"
      ]
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.12"
  }
}
